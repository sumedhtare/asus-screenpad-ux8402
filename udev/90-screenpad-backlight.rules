ACTION=="add", SUBSYSTEM=="backlight", RUN+="/usr/bin/chgrp video /sys/class/backlight/%k/brightness", RUN+="/usr/bin/chmod g+w /sys/class/backlight/%k/brightness"
ACTION=="add", SUBSYSTEM=="backlight", KERNEL=="asus_screenpad", RUN+="/usr/bin/chgrp video /sys/class/backlight/%k/bl_power", RUN+="/usr/bin/chmod g+w /sys/class/backlight/%k/bl_power"
